  ["criome-cozo",              "LiGoldragon/criome-cozo",              "CozoDB wrapper crate (leaf dependency)",                  "",                                       "sol", "proven"],
  ["samskara-lojix-contract",  "LiGoldragon/samskara-lojix-contract",  "Shared datalog relation schemas between agents",          "criome-cozo",                            "sol", "proven"],
  ["samskara",                 "LiGoldragon/samskara",                 "Pure datalog agent — sees only relations",                "criome-cozo,samskara-lojix-contract",    "sol", "proven"],
  ["lojix",                    "LiGoldragon/lojix",                    "DSL transpiler (TS phase 1, Rust phase 2)",               "criome-cozo,samskara-lojix-contract",    "sol", "proven"],
  ["Mentci",                   "LiGoldragon/Mentci",                   "Workspace (flake + dev shell + docs + samskara-world)",   "",                                       "sol", "proven"]
]
:put repo { name => github, purpose, depends_on, phase, dignity }

#── Repo state seed ─────────────────────────────────────────────────

?[name, bookmark, build_status, last_checked_ts, notes, phase, dignity] <- [
  ["criome-cozo",              "main",  "passing",  "2026-03-16",  "v0.7.13-alpha.3 cozo-ce, pins rayon 1.10.0",  "sol", "seen"],
  ["samskara-lojix-contract",  "main",  "passing",  "2026-03-16",  "3 contract relations, clean",                 "sol", "seen"],
  ["samskara",                 "v1",    "passing",  "2026-03-16",  "CLI + jj-mirror, main loop stubbed",          "sol", "seen"],
  ["lojix",                    "v1",    "passing",  "2026-03-16",  "CLI + transpile skeleton, all logic stubbed",  "sol", "seen"],
  ["Mentci",                   "main",  "n/a",      "2026-03-16",  "Workspace only — no build artifacts",         "sol", "seen"]
]
