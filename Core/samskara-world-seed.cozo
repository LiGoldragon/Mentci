#── Principle seed (doctrine) ──────────────────────────────────────

?[id, domain, rule, reason, phase, dignity] <- [
  ["p1", "data-ownership",   "Samskara NEVER sees files, code, or the OS — only relations",              "Pure datalog agent invariant",                      "sol", "eternal"],
  ["p2", "data-ownership",   "Each agent owns its own CozoDB — no shared database access",               "Sema data ownership principle",                     "sol", "eternal"],
  ["p3", "communication",    "Communication is ONLY through contract relations",                         "No RPC, no message bus, no shared state",           "sol", "eternal"],
  ["p4", "vcs",              "Jujutsu for VCS — git is storage backend only",                            "jj is the only allowed interface",                  "sol", "eternal"],
  ["p5", "build",            "Nix for builds, Rust for code — no exceptions",                            "Language policy",                                   "sol", "eternal"],
  ["p6", "architecture",     "Micro-repo style: each concern is its own repo, contracts too",            "Separation of concerns at repo boundary",           "sol", "eternal"],
  ["p7", "serialization",    "Binary format is Cap'n Proto — headerless data indexed by reader version", "Zero-copy, deterministic, self-describing envelope", "sol", "eternal"],
  ["p8", "version-control",  "samskara-vcs version-controls database changes, not files",                "Relations are the unit of change, not files",       "sol", "eternal"]
]
:put principle { id => domain, rule, reason, phase, dignity }

#── Thought seed ────────────────────────────────────────────────────

